                 "collectionTitle":  "æ”¶é›†æ–¹æ³•",
                 "freshnessTitle":  "æ•°æ®æ›´æ–°",
                 "metricsSection":  "æŒ‡æ ‡",
                 "measureTitle":  "æˆ‘ä»¬è¡¡é‡ä»€ä¹ˆ",
