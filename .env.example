GITHUB_TOKEN=your_github_token_here

# ── x402 Paid API — YOU receive the money ──────────────────────────────
# Set your wallet address to receive USDC payments on Base:
X402_PAY_TO=0x282A9f0387d7f1827AfDe519ac127531C7A6F7D2

# For production, point to a real x402 facilitator that will execute on-chain settlements:
# X402_FACILITATOR_URL=https://your-facilitator.com
# X402_MOCK_FACILITATOR=false

# Pricing (atomic units — USDC has 6 decimals, so 100000 = $0.10):
# X402_AMOUNT=100000
# X402_NETWORK=eip155:8453

# Local dev: skip payment entirely
# X402_FREE_TIER=true
